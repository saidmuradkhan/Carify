  "faq": [
    {
      "id": "1",
      "sual": "Niyə Cənubi Koreyadan ikinci əl avtomobil almalıyam?",
      "cavab": "Koreya daxili bazar avtomobilləri dünyada ən sərfəli variantlardan biridir. Yumşaq qışlar və az reagent istifadəsi kuzovun az korroziyaya uğramasına səbəb olur. Alıcılar adətən Avropa analoqlarına nisbətən 30–40% qənaət edir."
    },
    {
      "id": "2",
      "sual": "Alış prosesi addım-addım necə gedir?",
      "cavab": "Ofisə gəliş və müqavilənin imzalanması, xidmət haqqının ödənilməsi, avtomobilin axtarışı və yoxlanışı, rezervasiya, ödəniş, göndərilmə və gömrük rəsmiləşdirilməsi mərhələlərindən ibarətdir."
    },
    {
      "id": "3",
      "sual": "Xidmət haqqı var?",
      "cavab": "Bəli, xidmət haqqı avtomobil axtarışı başlamazdan əvvəl ödənilir."
    },
    {
      "id": "4",
      "sual": "Avtomobil dediyinizdən pis çıxsa, behim nə olur?",
      "cavab": "Avtomobil təsvirə uyğun gəlmədikdə müştəriyə alternativ təklif olunur və ya ödəniş geri qaytarılır."
    },
    {
      "id": "5",
      "sual": "Avtomobillər necə yoxlanılır?",
      "cavab": "Kuzov, alt hissə, mühərrik bölməsi, rəng qalınlığı ölçümü və rəsmi qəza tarixçəsi yoxlanılır. 5 video və 50-dən çox fotoşəkil təqdim edilir."
    },
    {
      "id": "6",
      "sual": "Avtomobil kimin adına olur?",
      "cavab": "Avtomobil rezerv olunduqdan sonra ixrac sənədləri birbaşa alıcının adına hazırlanır."
    },
    {
      "id": "7",
      "sual": "Ödəniş necə olur?",
      "cavab": "Rəsmi invoys əsasında 3 iş günü ərzində bank köçürməsi ilə həyata keçirilir."
    },
    {
      "id": "8",
      "sual": "Çatdırılma nə qədər çəkir?",
      "cavab": "Çin üzərindən 35-50 gün, Poti (Gürcüstan) üzərindən 95-115 gün."
    },
    {
      "id": "9",
      "sual": "Hansı ölkələrə çatdırırsınız?",
      "cavab": "Azərbaycan, Qazaxıstan, Qırğızıstan, Rusiya və Avropanın bir çox ölkəsinə."
    },
    {
      "id": "10",
      "sual": "Avtomobilin qəzalı və ya suda batmış olmadığını necə bilim?",
      "cavab": "Rəsmi NV tarixçəsi hesabatı və komputerli texniki yoxlama ilə təsdiqlənir."
    },
    {
      "id": "11",
      "sual": "Avtomobilin qiymətinə gömrük rüsumları daxildir?",
      "cavab": "Xeyr, saytda və ya təkliflərdə göstərilən ilkin qiymət yalnız Koreyadakı alış və logistika xərclərini əhatə edə bilər. Gömrük rəsmləşdirilməsi Azərbaycana çatdıqda yerli qanunvericiliyə uyğun olaraq ayrıca ödənilir."
    },
    {
      "id": "12",
      "sual": "Koreyadan hibrid avtomobil gətirmək sərfəlidirmi?",
      "cavab": "Bəli, hibrid avtomobillər həm ekoloji cəhətdən təmizdir, həm də Azərbaycanda gömrük rüsumlarında müəyyən güzəştli əmsallara (məsələn 0.7) malikdirlər ki, bu da son xərclərə qənaət edir."
    },
    {
      "id": "13",
      "sual": "Avtomobil yoldaykən sığortalanırmı?",
      "cavab": "Bəli, Carify vasitəsilə ixrac edilən bütün avtomobillər dəniz və quru daşınması müddətində yarana biləcək hər hansı fors-major hallara qarşı tam sığortalanır."
    },
    {
      "id": "14",
      "sual": "İstədiyim xüsusi komplektasiyanı sifariş edə bilərəm?",
      "cavab": "Bəli, biz müqavilə əsasında sizin tələblərinizə (rəng, disk ölçüsü, salon materialı, lyuk və s.) tam uyğun gələn avtomobilləri Encar və digər daxili bazarlardan axtarıb tapırıq."
    },
    {
      "id": "15",
      "sual": "Koreya avtomobillərinin yürüşü (probeq) orijinal olurmu?",
      "cavab": "Cənubi Koreyada yürüşün geri çəkilməsi ciddi qanuni məsuliyyət daşıyır. Eyni zamanda bizim müfəttişlər rəsmi dövlət sənədləri və texniki baxış tarixçəsi ilə yürüşün tam orijinallığını yoxlayırlar."
    },
    {
      "id": "16",
      "sual": "Sifarişi ləğv etmək mümkündürmü?",
      "cavab": "Avtomobil Koreya limanına yola düşməzdən əvvəl müəyyən şərtlərlə və yaranan ilkin xərclər tutulmaqla ləğv edilə bilər. Lakin ixrac bəyannaməsi yazıldıqdan sonra prosesi dayandırmaq mümkün deyil."
    },
    {
      "id": "17",
      "sual": "Bakıdakı ofisinizdə real avtomobillərə baxmaq olar?",
      "cavab": "Bəli, Bakı anbarımızda (və ya stokumuzda) olan və hazırda satışda olan avtomobilləri canlı yoxlaya bilərsiniz. Sifarişlə gələnlər isə birbaşa sahibinə təhvil verilir."
    },
    {
